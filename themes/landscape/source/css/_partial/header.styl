#header
  height: banner-height
  position: relative
  border-bottom: 1px solid rgba(255, 255, 255, 0.16)
  overflow: hidden
  &:before, &:after
    content: ""
    position: absolute
    left: 0
    right: 0
    height: 40px
  &:before
    top: 0
    background: linear-gradient(color-hero-overlay-strong, transparent)
  &:after
    bottom: 0
    background: linear-gradient(transparent, rgba(8, 18, 29, 0.5))

#header-outer
  height: 100%
  position: relative
  z-index: 1

#header-inner
  position: relative
  overflow: hidden
  display: flex
  align-items: center
  justify-content: space-between
  padding-top: 28px

#banner
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  background: linear-gradient(135deg, color-hero-overlay-strong, color-hero-overlay), url(banner-url) center #000
  background-size: cover
  z-index: -1

.header-backdrop
  position: absolute
  inset: 0
  background: radial-gradient(circle at 20% 20%, rgba(153, 246, 228, 0.16), transparent 24%), radial-gradient(circle at 82% 18%, rgba(96, 165, 250, 0.18), transparent 25%)

#header-title
  text-align: left
  height: auto
  position: absolute
  top: 50%
  left: 0
  right: 0
  transform: translateY(-36%)
  margin-top: 0
  max-width: 780px

.site-eyebrow
  display: inline-flex
  align-items: center
  gap: 10px
  font-size: 0.82em
  line-height: 1
  letter-spacing: 0.24em
  text-transform: uppercase
  color: rgba(255, 255, 255, 0.72)
  margin-bottom: 20px
  &:before
    content: ""
    width: 42px
    height: 1px
    background: rgba(255, 255, 255, 0.4)

$logo-text
  text-decoration: none
  color: #fff
  font-weight: 600
  text-shadow: 0 10px 32px rgba(0, 0, 0, 0.25)

#logo
  @extend $logo-text
  font-size: logo-size
  line-height: 1
  letter-spacing: -0.03em

#subtitle
  @extend $logo-text
  font-size: subtitle-size
  line-height: subtitle-size
  letter-spacing: 0.03em
  color: rgba(255, 255, 255, 0.72)

#subtitle-wrap
  margin-top: 18px

.header-description
  max-width: 640px
  margin-top: 24px
  font-size: 1.08em
  line-height: 1.9
  color: rgba(255, 255, 255, 0.78)

.header-actions
  display: flex
  flex-wrap: wrap
  gap: 14px
  margin-top: 30px

.header-action
  display: inline-flex
  align-items: center
  justify-content: center
  min-width: 148px
  padding: 12px 18px
  border-radius: 999px
  border: 1px solid rgba(255, 255, 255, 0.22)
  background: rgba(255, 255, 255, 0.08)
  color: #fff
  text-decoration: none
  font-weight: 600
  backdrop-filter: blur(12px)
  &:hover
    transform: translateY(-2px)
    box-shadow: 0 18px 30px rgba(0, 0, 0, 0.18)
  &.primary
    background: linear-gradient(135deg, #14b8a6, #0f766e)
    border-color: transparent

.header-meta
  display: flex
  flex-wrap: wrap
  gap: 12px
  margin-top: 26px
  span
    display: inline-flex
    align-items: center
    padding: 8px 12px
    border-radius: 999px
    background: rgba(255, 255, 255, 0.1)
    color: rgba(255, 255, 255, 0.76)
    font-size: 0.85em

#main-nav
  float: left

$nav-link
  float: left
  color: #fff
  opacity: 0.82
  text-decoration: none
  text-shadow: none
  transition: opacity 0.2s, background-color 0.2s, transform 0.2s
  display: block
  padding: 12px 14px
  border-radius: 999px
  &:hover
    opacity: 1
    background: rgba(255, 255, 255, 0.1)

.nav-icon
  @extend $nav-link
  text-align: center
  font-size: font-size
  width: font-size
  height: font-size
  padding: 12px 14px
  position: relative
  cursor: pointer

.main-nav-link
  @extend $nav-link
  font-weight: 500
  letter-spacing: 0.02em
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  @media mq-mobile
    display: block

#sub-nav
  float: right

#search-form-wrap
  position: absolute
  top: 14px
  width: 220px
  height: 42px
  right: -220px
  opacity: 0
  transition: 0.2s ease-out
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: rgba(255, 255, 255, 0.95)
  padding: 10px 16px
  border-radius: 999px
  box-shadow: 0 16px 35px rgba(15, 23, 32, 0.2)

.search-form-input
  border: none
  background: none
  color: color-default
  width: 100%
  font: 13px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none

.search-form-submit
  position: absolute
  top: 50%
  right: 14px
  margin-top: -7px
  font: 13px font-icon
  border: none
  background: none
  color: #bbb
  cursor: pointer
  &:hover, &:focus
    color: #777

@media mq-normal
  #header.is-home
    height: 520px

@media mq-tablet
  #header-title
    transform: translateY(-28%)
  #logo
    font-size: 46px

@media mq-mobile
  #header
    height: auto
    min-height: 520px
  #header-inner
    padding-top: 18px
  #header-title
    position: relative
    top: auto
    transform: none
    padding-top: 116px
    padding-bottom: 56px
  .header-description
    font-size: 1em
  .header-actions
    gap: 12px
  .header-action
    width: 100%
  .header-meta
    gap: 10px
